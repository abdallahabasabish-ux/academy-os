rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    function isTenantUser(tenantId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid));
    }
    
    function isOwner(tenantId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.ownerId == request.auth.uid;
    }
    
    function isStaff(tenantId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/users/$(request.auth.uid)).data.role in ['owner', 'admin', 'staff'];
    }

    // Public read for tenants
    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
      
      // Users subcollection
      match /users/{userId} {
        allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
        allow create: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
        allow update: if isAuthenticated() && (request.auth.uid == userId || isOwner(tenantId) || isAdmin());
        allow delete: if isAuthenticated() && (isOwner(tenantId) || isAdmin()) && request.auth.uid != userId;
      }
      
      // Staff subcollection
      match /staff/{staffId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
      }
      
      // Courses
      match /courses/{courseId} {
        allow read: if true;
        allow create: if isAuthenticated() && isStaff(tenantId);
        allow update, delete: if isAuthenticated() && (isStaff(tenantId) || isAdmin());
        
        match /chapters/{chapterId} {
          allow read: if true;
          allow write: if isAuthenticated() && isStaff(tenantId);
          
          match /lessons/{lessonId} {
            allow read: if true;
            allow write: if isAuthenticated() && isStaff(tenantId);
          }
        }
        
        match /enrollments/{studentId} {
          allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
          allow create: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == studentId);
          allow update: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == studentId);
        }
      }
      
      // Students
      match /students/{studentId} {
        allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
        allow create: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == studentId);
        allow update: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == studentId);
        allow delete: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
        
        match /progress/{courseId} {
          allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
          allow write: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == studentId);
        }
        
        match /payments/{paymentId} {
          allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
          allow write: if isAuthenticated() && isStaff(tenantId);
        }
      }
      
      // CRM
      match /crm/leads/{leadId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && isStaff(tenantId);
        
        match /communications/{commId} {
          allow read: if isAuthenticated() && isTenantUser(tenantId);
          allow write: if isAuthenticated() && isStaff(tenantId);
        }
      }
      
      // ERP
      match /erp/{document=**} {
        allow read: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
        allow write: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
      }
      
      // Exams
      match /exams/{examId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && isStaff(tenantId);
        
        match /questions/{questionId} {
          allow read: if isAuthenticated() && isTenantUser(tenantId);
          allow write: if isAuthenticated() && isStaff(tenantId);
        }
        
        match /results/{resultId} {
          allow read: if isAuthenticated() && (isTenantUser(tenantId) && (request.auth.uid == resultId || isStaff(tenantId)));
          allow create: if isAuthenticated() && (request.auth.uid == resultId || isStaff(tenantId));
          allow update: if isAuthenticated() && isStaff(tenantId);
        }
      }
      
      // Assignments
      match /assignments/{assignmentId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && isStaff(tenantId);
        
        match /submissions/{studentId} {
          allow read: if isAuthenticated() && (isTenantUser(tenantId) && (request.auth.uid == studentId || isStaff(tenantId)));
          allow write: if isAuthenticated() && (request.auth.uid == studentId || isStaff(tenantId));
        }
      }
      
      // Certificates
      match /certificates/{certificateId} {
        allow read: if true;
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Store
      match /store/products/{productId} {
        allow read: if true;
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      match /store/orders/{orderId} {
        allow read: if isAuthenticated() && (isTenantUser(tenantId) || isAdmin());
        allow write: if isAuthenticated() && (isStaff(tenantId) || request.auth.uid == orderId);
      }
      
      // Coupons
      match /coupons/{couponId} {
        allow read: if true;
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Blog
      match /blog/posts/{postId} {
        allow read: if true;
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Notifications
      match /notifications/{notificationId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId) && 
          get(/databases/$(database)/documents/tenants/$(tenantId)/notifications/$(notificationId)).data.userId == request.auth.uid;
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Calendar
      match /calendar/events/{eventId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Pages (Page Builder)
      match /pages/{pageSlug} {
        allow read: if get(/databases/$(database)/documents/tenants/$(tenantId)/pages/$(pageSlug)).data.status == 'published' || 
          (isAuthenticated() && isTenantUser(tenantId));
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Files
      match /files/{fileId} {
        allow read: if isAuthenticated() && isTenantUser(tenantId);
        allow write: if isAuthenticated() && isStaff(tenantId);
      }
      
      // Audit Logs
      match /audit_logs/{logId} {
        allow read: if isAuthenticated() && (isOwner(tenantId) || isAdmin());
        allow write: if false;
      }
    }
    
    // Platform level (admin only)
    match /platform/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
